# ─── Contentful (real integration) ────────────────────────────────────────
# Space + environment from Contentful → Settings → API keys
CONTENTFUL_SPACE_ID=your_space_id
CONTENTFUL_ENVIRONMENT=master

# Content Delivery API token (published content)
CONTENTFUL_CDA_TOKEN=your_cda_token
# Content Preview API token (draft content)
CONTENTFUL_CPA_TOKEN=your_cpa_token

# When "true", the adapter uses the Preview API (draft content) by default.
# Per-request override is also supported via the adapter `preview` flag.
CONTENTFUL_PREVIEW=false

# ─── Auth / RBAC ───────────────────────────────────────────────────────────
# Secret used to sign the session cookie (HMAC). Generate: openssl rand -hex 32
AUTH_SECRET=replace_with_32_byte_hex_secret

# ─── Release store ─────────────────────────────────────────────────────────
# "fs" (default, writes to ./releases) or "memory" (ephemeral, for tests/preview).
RELEASE_STORE_DRIVER=fs
